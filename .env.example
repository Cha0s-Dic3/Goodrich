PAYPACK_CLIENT_ID=your_client_id_here
PAYPACK_CLIENT_SECRET=your_client_secret_here
PAYPACK_WEBHOOK_SECRET=your_webhook_secret_here
PAYPACK_WEBHOOK_MODE=production
JWT_SECRET=replace_with_strong_secret
NODE_ENV=development
PORT=5174
APP_BASE_URL=http://localhost:5173

# SMTP (required for password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Firebase Storage (optional but recommended in production)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
